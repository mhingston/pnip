# PostgreSQL
DATABASE_URL=postgres://user:password@127.0.0.1:5432/pnip
TEST_DATABASE_URL=postgres://user:password@127.0.0.1:5432/pnip_test

# Miniflux
MINIFLUX_URL=http://127.0.0.1:8080
MINIFLUX_API_TOKEN=replace-me

# AI provider credentials
OPENAI_API_KEY=replace-me
GOOGLE_GENERATIVE_AI_API_KEY=replace-me

# Optional: override the OpenAI-compatible base URL (used by AI_PROVIDER=openai
# and AI_PROVIDER=openai-compatible; @ai-sdk/openai and the local
# OpenAI-compatible provider both read this).
# OPENAI_BASE_URL=https://api.openai.com/v1

# AI provider selection:
#   "openai"               — @ai-sdk/openai (default, OpenAI Responses API)
#   "openai-compatible"    — thin fetch-based provider for OpenAI-compatible
#                            chat-completions endpoints (combines reasoning_content
#                            into content); needs OPENAI_BASE_URL + OPENAI_API_KEY
#   "fake"                 — deterministic offline dev/test provider
AI_PROVIDER=openai
# Optional: override the default text model (default: gpt-4o-mini via Vercel AI SDK)
# AI_TEXT_MODEL=gpt-4o-mini
# Optional: override the embedding model (default: Xenova/all-MiniLM-L6-v2, 384-dim)
# EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
# Optional: local cache directory for the embedding model
# EMBEDDING_CACHE_DIR=./.cache/transformers

# Fabric CLI (path to the fabric binary; optional)
FABRIC_BIN=fabric

# MarkItDown CLI (path to the markitdown binary; optional)
MARKITDOWN_BIN=markitdown

# Resend credentials
RESEND_API_KEY=replace-me
EMAIL_FROM=digest@example.com
EMAIL_RECIPIENT=recipient@example.com

# Optional presentation calibration. Reading time changes prominence only;
# all stories and sources remain in the canonical Markdown digest.
# DIGEST_TARGET_READING_MINUTES=10
# Set only from an explicit editorial significance/novelty assessment.
# DIGEST_QUIET_EDITION_REASON=low_novelty

# notebooklm-py configuration
NOTEBOOKLM_OUTPUT_DIR=./notebooks
NOTEBOOKLM_HEADLESS=true
# Optional: cap on documents uploaded to a single NotebookLM notebook (default: 50)
# NOTEBOOKLM_MAX_SOURCES_PER_NOTEBOOK=50

# Edition scheduling
EDITION_SCHEDULE=0 6 * * *

# Reddit enrichment
REDDIT_REFRESH_STRATEGY=top-n

# Worker concurrency
WORKER_CONCURRENCY=4

# Retry policy
RETRY_MAX_ATTEMPTS=3

# Logging
LOG_LEVEL=info

# Partition configuration (per-category notebook editions)
# JSON object keyed by partition name. Each entry supports:
#   category       Miniflux category title (case-insensitive)
#   category_id    Miniflux category numeric id (alternative to `category`)
#   min_articles   minimum documents required for the partition to be active
#                  on a given day; non-master partitions below the threshold
#                  are silently suppressed. Default: 5.
#   enabled        include this partition in the active-partition set (default true)
#   with_podcast   also produce a NotebookLM podcast for this partition (default false)
# Example (one YouTube-only notebook with a podcast):
# PARTITION_CONFIG={"youtube":{"category":"YouTube","min_articles":5,"enabled":true,"with_podcast":true}}
# Leave unset (or empty) to use the master-only default — every entry goes to
# `master`, behaviour is identical to pre-feature PNIP, and no extra notebooks
# are produced.
# PARTITION_CONFIG=
